\def\bbl@german@disc#1#2#3{%
  \ifbbl@german@tradspelling
    \textormath{%
      \bbl@german@allowhyphenationbefore\discretionary{#2-}{}{#1}%
      \bbl@german@allowhyphenationafter
    }{#1}% math
  \else
    #3%
  \fi
}
