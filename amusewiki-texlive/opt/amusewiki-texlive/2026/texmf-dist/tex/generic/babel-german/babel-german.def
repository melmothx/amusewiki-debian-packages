    \ifx\bbl@german@region\bbl@german@region@de
       \ifbbl@german@tradspelling
          \@namedef{extrasgerman}{%
             \@nameuse{@extrasgerman}%
          }
          \@namedef{extras\CurrentOption}{%
             \@nameuse{extrasgerman}%
          }
       \else
         \@namedef{extrasngerman}{%
            \@nameuse{@extrasgerman}%
         }
         \@namedef{extras\CurrentOption}{%
            \@nameuse{extrasngerman}%
         }
       \fi
    \fi
  \fi
\fi
