name hyphen-kurmanji
category TLCore
revision 78069
shortdesc Kurmanji hyphenation patterns.
longdesc Hyphenation patterns for Kurmanji (Northern Kurdish) as spoken
longdesc in Turkey and by the Kurdish diaspora in Europe, in T1/EC and
longdesc UTF-8 encodings.
depend hyph-utf8
depend hyphen-base
execute AddHyphen 	name=kurmanji 	lefthyphenmin=2 	righthyphenmin=2 	file=loadhyph-kmr.tex 	file_patterns=hyph-kmr.pat.txt 	file_exceptions=
containersize 2700
containerchecksum 19878db2775d3dad30321d175eba2f6f35858c02994ce8e7e00d3cd41e22f798f4ce6a2e86eb7b70f5bbe8cda759ff92bd65a2950f3d07f4a996daf4d78da74b
runfiles size=4
 texmf-dist/tex/generic/hyph-utf8/loadhyph/loadhyph-kmr.tex
 texmf-dist/tex/generic/hyph-utf8/patterns/ptex/hyph-kmr.ec.tex
 texmf-dist/tex/generic/hyph-utf8/patterns/tex/hyph-kmr.tex
 texmf-dist/tex/generic/hyph-utf8/patterns/txt/hyph-kmr.pat.txt
