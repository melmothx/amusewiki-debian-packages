name hyphen-interlingua
category TLCore
revision 78069
shortdesc Interlingua hyphenation patterns.
longdesc Hyphenation patterns for Interlingua in ASCII encoding.
depend hyph-utf8
depend hyphen-base
execute AddHyphen 	name=interlingua 	lefthyphenmin=2 	righthyphenmin=2 	file=loadhyph-ia.tex 	file_patterns=hyph-ia.pat.txt 	file_exceptions=hyph-ia.hyp.txt
containersize 2880
containerchecksum ad81c2d807e54a31bec0e8ed7fb71eb95e988c182652a32bf8133bb4774ec8d79ef983fd7ca2b53b32a4e6a5776b76d478ddb3d9ece4614e627e596aad1ad8e9
runfiles size=5
 texmf-dist/tex/generic/hyph-utf8/loadhyph/loadhyph-ia.tex
 texmf-dist/tex/generic/hyph-utf8/patterns/tex/hyph-ia.tex
 texmf-dist/tex/generic/hyph-utf8/patterns/txt/hyph-ia.hyp.txt
 texmf-dist/tex/generic/hyph-utf8/patterns/txt/hyph-ia.pat.txt
