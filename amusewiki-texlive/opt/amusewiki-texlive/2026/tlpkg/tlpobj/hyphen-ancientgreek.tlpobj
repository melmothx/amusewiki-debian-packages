name hyphen-ancientgreek
category TLCore
revision 78069
shortdesc Ancient Greek hyphenation patterns.
longdesc Hyphenation patterns for Ancient Greek in LGR and UTF-8
longdesc encodings, including support for (obsolete) Ibycus font
longdesc encoding. Patterns in UTF-8 use two code positions for each of
longdesc the vowels with acute accent (a.k.a tonos, oxia), e.g., U+03AE,
longdesc U+1F75 for eta.
depend hyph-utf8
depend hyphen-base
execute AddHyphen 	name=ancientgreek 	lefthyphenmin=1 	righthyphenmin=1 	file=loadhyph-grc.tex 	file_patterns=hyph-grc.pat.txt 	file_exceptions=
execute AddHyphen 	name=ibycus 	lefthyphenmin=2 	righthyphenmin=2 	file=ibyhyph.tex 	luaspecial="disabled:8-bit only"
containersize 38280
containerchecksum a473f01224a3c6a2823cb66b23e101dc963c295dacc364c5b7efce2924c89b9042294565ee31960743d1902da75dde0752ba45386026fbe7465034842364f093
runfiles size=54
 texmf-dist/tex/generic/hyph-utf8/loadhyph/loadhyph-grc.tex
 texmf-dist/tex/generic/hyph-utf8/patterns/tex/hyph-grc.tex
 texmf-dist/tex/generic/hyph-utf8/patterns/txt/hyph-grc.pat.txt
 texmf-dist/tex/generic/hyphen/grahyph5.tex
 texmf-dist/tex/generic/hyphen/ibyhyph.tex
