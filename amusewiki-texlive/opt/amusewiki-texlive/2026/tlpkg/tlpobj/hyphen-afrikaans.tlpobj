name hyphen-afrikaans
category TLCore
revision 78069
shortdesc Afrikaans hyphenation patterns.
longdesc Hyphenation patterns for Afrikaans in T1/EC and UTF-8
longdesc encodings. OpenOffice includes older patterns created by a
longdesc different author, but the patterns packaged with TeX are
longdesc considered superior in quality.
depend hyph-utf8
depend hyphen-base
execute AddHyphen 	name=afrikaans 	lefthyphenmin=1 	righthyphenmin=2 	file=loadhyph-af.tex 	file_patterns=hyph-af.pat.txt 	file_exceptions=hyph-af.hyp.txt
containersize 37008
containerchecksum 2c00d0723c06809728695deeb8d78e4f4aecf951aaf46ccf00aede446fadbe92b37445eebd7dd94ded423a1c18dabc4f68921cd2a65a73e35a3961f58c033175
runfiles size=62
 texmf-dist/tex/generic/hyph-utf8/loadhyph/loadhyph-af.tex
 texmf-dist/tex/generic/hyph-utf8/patterns/ptex/hyph-af.ec.tex
 texmf-dist/tex/generic/hyph-utf8/patterns/quote/hyph-quote-af.tex
 texmf-dist/tex/generic/hyph-utf8/patterns/tex/hyph-af.tex
 texmf-dist/tex/generic/hyph-utf8/patterns/txt/hyph-af.hyp.txt
 texmf-dist/tex/generic/hyph-utf8/patterns/txt/hyph-af.pat.txt
