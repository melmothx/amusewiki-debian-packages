depend latex
depend latex-base-dev
depend latex-firstaid-dev
depend latex-fonts
depend platex
depend tex-ini-files
depend unicode-data
depend uplatex.ARCH
depend uptex
depend uptex-fonts
execute AddFormat name=uplatex engine=euptex options="*uplatex.ini"           patterns=language.dat           fmttriggers=uptex-fonts,platex,l3backend,l3kernel,latex,firstaid,babel,cm,hyphen-base,knuth-lib,latex-fonts,tex-ini-files,unicode-data
execute AddFormat name=uplatex-dev engine=euptex options="*uplatex.ini"           patterns=language.dat           fmttriggers=uptex-fonts,platex,l3backend-dev,l3kernel-dev,latex-base-dev,latex-firstaid-dev,babel,cm,hyphen-base,knuth-lib,latex-fonts,tex-ini-files,unicode-data
